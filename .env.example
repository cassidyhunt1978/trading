# Database Configuration
DATABASE_URL=postgresql://trading:changeme@127.0.0.1:5432/trading_system
DB_PASSWORD=changeme

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379/0

# Service Communication (for internal service-to-service API calls)
SERVICE_HOST=127.0.0.1

# AI API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Sentiment Analysis APIs
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TradingBot/1.0

TWITTER_BEARER_TOKEN=your_twitter_bearer_token

NEWSAPI_KEY=your_newsapi_key

# Coinbase API (preferred for better free tier - leave empty for paper trading)
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Kraken API (legacy/backup - leave empty for paper trading)
KRAKEN_API_KEY=
KRAKEN_SECRET_KEY=

# System Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# Trading Configuration
PAPER_STARTING_CAPITAL=10000.00
DAILY_TARGET_PCT=0.05
MIN_SIGNAL_QUALITY=60

# Server Ports
PORT_AI_API=8011
PORT_OHLCV_API=8012
PORT_BACKTEST_API=8013
PORT_OPTIMIZATION_API=8014
PORT_SIGNAL_API=8015
PORT_PORTFOLIO_API=8016
PORT_TRADING_API=8017
PORT_AFTERACTION_API=8018
PORT_TESTING_API=8019
